{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": "allow",
    "doom_loop": "ask",
    "edit": "allow",
    "external_directory": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.dev.vars": "deny",
      "*.env.*": "deny"
    },
    "webfetch": "allow"
  },
  "plugin": ["oh-my-opencode@latest"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        }
      }
    }
  }
}
