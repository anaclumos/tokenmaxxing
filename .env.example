# Clerk (org-only auth) -- not needed when BYPASS_AUTH=true
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon Postgres (production) or local Docker Postgres
DATABASE_URL=postgres://tokenmaxxing:tokenmaxxing@localhost:5432/tokenmaxxing

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Encryption (KEK for envelope encryption of BYOK keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Cron auth
CRON_SECRET=

# Bypass Clerk auth for local dev / E2E tests
BYPASS_AUTH=true
NEXT_PUBLIC_BYPASS_AUTH=true
